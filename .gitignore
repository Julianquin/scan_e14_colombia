# Los JSON son datos de entrada/salida (índices del scraper como
# allTransmissionCodes.json / departmentsTree.json, _resumen_lote.json, etc.):
# son externos o se generan, no se versionan. Si algún día hace falta versionar
# un JSON de configuración, añádelo con `git add -f` o crea una excepción aquí.

# =============================================================
#  ScanE14 — .gitignore
#  Regla de oro: el código se versiona; los datos y los modelos NO.
#  Todo lo pesado/generado vive en data/ y models/ (fuera de git).
# =============================================================

# Datos no versionados: PDFs, PNG y carpetas de datos en cualquier nivel
**/*.pdf

**/*.png
**/*.gz
**/*.zip
**/*.csv
**/*.jsonl
**/*.pt
**/*.npz

**/recortes_ocr/
**/e14_pdfs/
resultados/

latest.json

# --- Datos y artefactos generados (directorios completos) ---
data/
models/

# Por si algún artefacto cae fuera de data/ durante la migración:
e14_pdfs/
recortes*/
dataset_digitos*/
codes_snapshots*/
resultados/
e14_pdfs_claveros/

**/cajas/

# --- Manifiestos de entrada del scraper (36+ MB, NO al repo) ---
allTransmissionCodes*.json
departmentsTree*.json
latest.json

# --- Tipos de fichero pesados / artefactos ---
*.pdf
*.pt
*.pth
*.onnx
*.npz
*.npy
*.gz
*.zip

# --- Pesos / salidas que conviene no commitear ---
digitnet*.pt
numeros_leidos.csv
actas_verificadas.csv
actas_decodificadas.csv
reporte_auditoria.csv

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.ipynb_checkpoints/

# --- Entornos virtuales ---
.venv/
venv/
env/
.conda/

# --- Editor / SO ---
.vscode/
.idea/
.DS_Store
Thumbs.db

# --- Secretos / configuración local ---
.env
*.local